PORT=5000
# HTTPS=true افتراضي (مطلوب للمكالمات من جهاز آخر). لو ظهر خطأ SSL ضع HTTPS=false
# HTTPS=false

MONGO_URI=mongodb://127.0.0.1:27017/whatsapp_clone
# للإنتاج: استخدم MongoDB Atlas مجاناً: https://cloud.mongodb.com
# MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/whatsapp_clone

JWT_SECRET=supersecretkey

# للنشر السحابي: ضع رابط التطبيق النهائي (مثال: https://karas-magdy.onrender.com)
# BASE_URL=https://your-app.onrender.com

# لوحة الأدمن (Admin Panel)
# APPROVAL_MODE=true يطلب موافقة الأدمن للمستخدمين الجدد
APPROVAL_MODE=false

# IDs للأدمن (من MongoDB) مفصولة بفاصلة
# ADMIN_USER_IDS=id1,id2,id3

# أرقام الموبايل للأدمن (أسهل للإعداد الأولي) مفصولة بفاصلة
# ADMIN_PHONES=1111111111,2222222222

# Giphy - مفتاح من https://developers.giphy.com/dashboard/
# GIPHY_API_KEY=your_key_here
